async function decompressTGS(compressed) {
  try {
    const ds = new DecompressionStream('gzip');
    const writer = ds.writable.getWriter();
    const reader = ds.readable.getReader();
    await writer.write(compressed);
    await writer.close();
    const chunks = [];
    let result;
    while (!(result = await reader.read()).done) chunks.push(result.value);
    const totalLength = chunks.reduce((acc, chunk) => acc + chunk.length, 0);
    const decompressed = new Uint8Array(totalLength);
    let offset = 0;
    for (const chunk of chunks) { decompressed.set(chunk, offset); offset += chunk.length; }
    return decompressed;
  } catch (e) { throw new Error('corruptedFile'); }
}

async function compressToTGS(data) {
  try {
    const buffer = typeof data === 'string' ? new TextEncoder().encode(data) : data instanceof Uint8Array ? data : new Uint8Array(data);
    if (buffer.length === 0) throw new Error('Buffer is empty');
    const cs = new CompressionStream('gzip');
    const writer = cs.writable.getWriter();
    const reader = cs.readable.getReader();
    await writer.write(buffer);
    await writer.close();
    const chunks = [];
    let readResult;
    while (true) { readResult = await reader.read(); if (readResult.done) break; chunks.push(readResult.value); }
    const totalLength = chunks.reduce((acc, chunk) => acc + chunk.length, 0);
    const compressed = new Uint8Array(totalLength);
    let offset = 0;
    for (const chunk of chunks) { compressed.set(chunk, offset); offset += chunk.length; }
    if (compressed.length === 0) throw new Error('Compression resulted in empty buffer');
    return compressed;
  } catch (e) { throw e; }
}

async function getCustomEmojiTGS(customEmojiId) {
  try {
    const response = await fetch(`${TELEGRAM_API}/getCustomEmojiStickers`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ custom_emoji_ids: [customEmojiId] })
    });
    const data = await response.json();
    if (!data.ok || !data.result || data.result.length === 0) throw new Error('getEmojiError');
    return { file_id: data.result[0].file_id, is_video: data.result[0].is_video, premium_animation: data.result[0].premium_animation };
  } catch (e) { throw new Error('getEmojiError'); }
}

async function processFile(fileId, fileName, fileType, chatId, userId, premiumAnimationFileId = null) {
  try {
    const fileResponse = await fetch(`${TELEGRAM_API}/getFile?file_id=${fileId}`);
    const fileData = await fileResponse.json();
    if (!fileData.ok) throw new Error('getFileError');
    const filePath = fileData.result.file_path;
    const downloadUrl = `https://api.telegram.org/file/bot${TELEGRAM_BOT_TOKEN}/${filePath}`;
    const fileBuffer = await fetch(downloadUrl).then(r => r.arrayBuffer());

    let jsonContent = '';
    if (fileName.endsWith('.tgs') || fileType === 'emoji' || fileType === 'sticker') {
      const decompressed = await decompressTGS(new Uint8Array(fileBuffer));
      jsonContent = new TextDecoder().decode(decompressed);
    } else if (fileName.endsWith('.json')) {
      jsonContent = new TextDecoder().decode(new Uint8Array(fileBuffer));
    } else {
      throw new Error('invalidFile');
    }

    let lightLockedJson;
    try { lightLockedJson = lightLockLottieFile(jsonContent); } catch (e) { throw new Error('corruptedFile'); }
    try { JSON.parse(lightLockedJson); } catch (e) { throw new Error('corruptedFile'); }

    let lockedJson;
    try { lockedJson = lockLottieFile(jsonContent); } catch (e) { throw new Error('corruptedFile'); }
    try { JSON.parse(lockedJson); } catch (e) { throw new Error('corruptedFile'); }

    let baseFileName;
    if (fileType === 'tgs') baseFileName = fileName.replace(/\.tgs$/, '');
    else if (fileType === 'json') baseFileName = fileName.replace(/\.json$/, '');
    else if (fileType === 'sticker') baseFileName = `sticker_${Date.now()}`;
    else if (fileType === 'emoji') baseFileName = `emoji_${Date.now()}`;
    else baseFileName = fileName.replace(/\.(json|tgs)$/, '');

    const sanitize = name => name.replace(/[<>:"|?*]/g, '_').substring(0, 255);
    const jsonFileName = sanitize(`${baseFileName}_Locked.json`);
    const tgsFileName = sanitize(`${baseFileName}_Locked.tgs`);

    const jsonBlob = new Blob([lockedJson], { type: 'application/json' });
    const jsonFormData = new FormData();
    jsonFormData.append('chat_id', chatId);
    jsonFormData.append('document', jsonBlob, jsonFileName);
    await fetch(`${TELEGRAM_API}/sendDocument`, { method: 'POST', body: jsonFormData });

    const tgsBuffer = await compressToTGS(lockedJson);
    const tgsBlob = new Blob([tgsBuffer], { type: 'application/octet-stream' });
    const tgsFormData = new FormData();
    tgsFormData.append('chat_id', chatId);
    tgsFormData.append('document', tgsBlob, tgsFileName);
    await fetch(`${TELEGRAM_API}/sendDocument`, { method: 'POST', body: tgsFormData });

    if (tgsBuffer.length > TGS_SIZE_WARNING_THRESHOLD) {
      await fetch(`${TELEGRAM_API}/sendMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text: t(userId, 'tgsSizeWarning'), parse_mode: 'Markdown' })
      });
    }

    if (premiumAnimationFileId) {
      try {
        const premiumFileResponse = await fetch(`${TELEGRAM_API}/getFile?file_id=${premiumAnimationFileId}`);
        const premiumFileData = await premiumFileResponse.json();
        if (premiumFileData.ok) {
          const premiumFilePath = premiumFileData.result.file_path;
          const premiumDownloadUrl = `https://api.telegram.org/file/bot${TELEGRAM_BOT_TOKEN}/${premiumFilePath}`;
          const premiumFileBuffer = await fetch(premiumDownloadUrl).then(r => r.arrayBuffer());
          const premiumDecompressed = await decompressTGS(new Uint8Array(premiumFileBuffer));
          const premiumJsonContent = new TextDecoder().decode(premiumDecompressed);
          const premiumLockedJson = lockLottieFile(premiumJsonContent);
          const premiumJsonFileName = sanitize(jsonFileName.replace(/\.json$/, '_PremiumEffect_Locked.json'));
          const premiumJsonBlob = new Blob([premiumLockedJson], { type: 'application/json' });
          const premiumJsonFormData = new FormData();
          premiumJsonFormData.append('chat_id', chatId);
          premiumJsonFormData.append('document', premiumJsonBlob, premiumJsonFileName);
          await fetch(`${TELEGRAM_API}/sendDocument`, { method: 'POST', body: premiumJsonFormData });
          const premiumTgsFileName = sanitize(tgsFileName.replace(/\.tgs$/, '_PremiumEffect_Locked.tgs'));
          const premiumTgsBuffer = await compressToTGS(premiumLockedJson);
          const premiumTgsBlob = new Blob([premiumTgsBuffer], { type: 'application/octet-stream' });
          const premiumTgsFormData = new FormData();
          premiumTgsFormData.append('chat_id', chatId);
          premiumTgsFormData.append('document', premiumTgsBlob, premiumTgsFileName);
          await fetch(`${TELEGRAM_API}/sendDocument`, { method: 'POST', body: premiumTgsFormData });
          if (premiumTgsBuffer.length > TGS_SIZE_WARNING_THRESHOLD) {
            await fetch(`${TELEGRAM_API}/sendMessage`, {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ chat_id: chatId, text: t(userId, 'tgsSizeWarning'), parse_mode: 'Markdown' })
            });
          }
        }
      } catch (error) { console.error('Error processing premium animation:', error); }
    }

    await fetch(`${TELEGRAM_API}/sendMessage`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ chat_id: chatId, text: t(userId, 'fileLocked') })
    });
    console.log(`✅ Locked (full): ${fileName}, Type: ${fileType}`);
  } catch (error) {
    console.error('processFile error:', error);
    throw error;
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// ОСНОВНОЙ ОБРАБОТЧИК ОБНОВЛЕНИЙ
// ─────────────────────────────────────────────────────────────────────────────
async function handleTelegramUpdate(update) {
  try {
    const userId = update.message?.from?.id || update.callback_query?.from?.id;
    const chatId = update.message?.chat?.id || update.callback_query?.message?.chat?.id;
    if (!chatId || !userId) return;

    // ── Выбор языка (первичный) ──
    if (update.callback_query?.data?.startsWith('initial_lang_')) {
      const lang = update.callback_query.data.replace('initial_lang_', '');
      setUserLanguage(userId, lang);
      await fetch(`${TELEGRAM_API}/deleteMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, message_id: update.callback_query.message.message_id })
      });
      const isSubscribed = await checkChannelSubscription(userId);
      if (isSubscribed) await sendWelcomeMessage(chatId, userId);
      else await sendSubscriptionRequiredMessage(chatId, userId);
      return;
    }

    // ── Смена языка ──
    if (update.callback_query?.data?.startsWith('lang_')) {
      const lang = update.callback_query.data.replace('lang_', '');
      setUserLanguage(userId, lang);
      await fetch(`${TELEGRAM_API}/deleteMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, message_id: update.callback_query.message.message_id })
      });
      await fetch(`${TELEGRAM_API}/sendMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text: t(userId, 'languageChanged') })
      });
      return;
    }

    // ── Команды ──
    if (update.message?.text === '/start') { await sendInitialLanguageSelection(chatId); return; }
    if (update.message?.text === '/lang') { await sendLanguageSelection(chatId); return; }

    // ── Проверка подписки ──
    if (update.callback_query?.data === 'check_subscription') {
      const callbackQueryId = update.callback_query.id;
      const messageId = update.callback_query.message.message_id;
      try {
        const isSubscribed = await checkChannelSubscription(userId);
        if (isSubscribed) {
          await fetch(`${TELEGRAM_API}/deleteMessage`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ chat_id: chatId, message_id: messageId })
          });
          await fetch(`${TELEGRAM_API}/answerCallbackQuery`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ callback_query_id: callbackQueryId, text: t(userId, 'subscriptionConfirmed'), show_alert: false })
          });
          await sendWelcomeMessage(chatId, userId);
        } else {
          await fetch(`${TELEGRAM_API}/answerCallbackQuery`, {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ callback_query_id: callbackQueryId, text: t(userId, 'subscriptionFailed'), show_alert: true })
          });
        }
      } catch (error) {
        await fetch(`${TELEGRAM_API}/answerCallbackQuery`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ callback_query_id: callbackQueryId, text: t(userId, 'subscriptionError'), show_alert: true })
        });
      }
      return;
    }

    if (!update.message) return;

    // ── Определяем тип входящего файла ──
    let isFileOrEmoji = false, fileType = null;
    if (update.message?.document) {
      isFileOrEmoji = true;
      const fn = update.message.document.file_name || '';
      if (fn.endsWith('.tgs')) fileType = 'tgs';
      else if (fn.endsWith('.json')) fileType = 'json';
      else if (fn.toLowerCase().endsWith('.svg')) fileType = 'svg';
    } else if (update.message?.sticker) {
      isFileOrEmoji = true;
      fileType = update.message.sticker.is_animated ? 'sticker' : 'rasterSticker';
    } else if (update.message?.entities) {
      for (const entity of update.message.entities) {
        if (entity.type === 'custom_emoji') { isFileOrEmoji = true; fileType = 'emoji'; break; }
      }
    }

    if (isFileOrEmoji) {
      const isSubscribed = await checkChannelSubscription(userId);
      if (!isSubscribed) { await sendSubscriptionRequiredMessage(chatId, userId); return; }
      if (fileType === 'rasterSticker') {
        await fetch(`${TELEGRAM_API}/sendMessage`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ chat_id: chatId, text: `❌ ${t(userId, 'rasterStickerError')}` })
        });
        return;
      }
    } else return;

    // ── SVG → TGS glitch ──
    if (fileType === 'svg' && update.message?.document) {
      const fileId = update.message.document.file_id;
      const fileName = update.message.document.file_name || 'image.svg';
      await fetch(`${TELEGRAM_API}/sendMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text: getProcessingMessage(userId, 'svg') })
      });
      await processSvgFile(fileId, fileName, chatId, userId);
      return;
    }

    // ── Custom emoji ──
    if (update.message?.entities) {
      for (const entity of update.message.entities) {
        if (entity.type === 'custom_emoji') {
          const customEmojiId = entity.custom_emoji_id;
          try {
            const emojiData = await getCustomEmojiTGS(customEmojiId);
            if (emojiData.is_video) {
              await fetch(`${TELEGRAM_API}/sendMessage`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ chat_id: chatId, text: `❌ ${t(userId, 'rasterEmojiError')}` })
              });
              return;
            }
            await fetch(`${TELEGRAM_API}/sendMessage`, {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ chat_id: chatId, text: getProcessingMessage(userId, 'emoji') })
            });
            await processFile(emojiData.file_id, `emoji_${customEmojiId}.tgs`, 'emoji', chatId, userId, emojiData.premium_animation?.file_id);
            return;
          } catch (error) { throw error; }
        }
      }
    }

    // ── Документ / стикер (lock) ──
    let fileId = null, fileName = null, currentFileType = null, premiumAnimationFileId = null;
    if (update.message?.document) {
      fileId = update.message.document.file_id;
      fileName = update.message.document.file_name || 'file';
      if (fileName.endsWith('.tgs')) currentFileType = 'tgs';
      else if (fileName.endsWith('.json')) currentFileType = 'json';
      else throw new Error('invalidFile');
    } else if (update.message?.sticker) {
      fileId = update.message.sticker.file_id;
      if (update.message.sticker.is_animated) {
        fileName = `sticker_${Date.now()}.tgs`;
        currentFileType = 'sticker';
        if (update.message.sticker.premium_animation) premiumAnimationFileId = update.message.sticker.premium_animation.file_id;
      } else return;
    } else return;

    await fetch(`${TELEGRAM_API}/sendMessage`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ chat_id: chatId, text: getProcessingMessage(userId, currentFileType) })
    });
    await processFile(fileId, fileName, currentFileType, chatId, userId, premiumAnimationFileId);

  } catch (error) {
    const userId = update.message?.from?.id || update.callback_query?.from?.id;
    const chatId = update.message?.chat?.id || update.callback_query?.message?.chat?.id;
    console.error('Error:', error);
    if (chatId) {
      const errorMessage = error.message;
      const translatedError = LANGUAGES[getUserLanguage(userId)]?.[errorMessage] || errorMessage;
      await fetch(`${TELEGRAM_API}/sendMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text: `❌ ${translatedError}` })
      });
    }
  }
}

// ─────────────────────────────────────────────────────────────────────────────
// CLOUDFLARE WORKER EXPORT
// ─────────────────────────────────────────────────────────────────────────────
export default {
  async fetch(request, env, ctx) {
    if (request.method === 'POST') {
      const update = await request.json();
      ctx.waitUntil(handleTelegramUpdate(update));
      return new Response('OK');
    }
    return new Response('🤖 Send .tgs / .json to lock, or .svg for glitch effect');
  }
};
