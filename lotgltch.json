// ЯЗЫКОВЫЕ УТИЛИТЫ
// ─────────────────────────────────────────────────────────────────────────────
const userLanguages = new Map();
function getUserLanguage(userId) { return userLanguages.get(userId) || 'ru'; }
function setUserLanguage(userId, language) { userLanguages.set(userId, language); }
function t(userId, key) { const lang = getUserLanguage(userId); return LANGUAGES[lang]?.[key] || LANGUAGES['ru'][key] || key; }
function getProcessingMessage(userId, fileType) {
  const key = { 'emoji': 'processingEmoji', 'sticker': 'processingSticker', 'tgs': 'processingFile', 'json': 'processingFile', 'svg': 'processingSvg' }[fileType] || 'processing';
  return t(userId, key);
}

