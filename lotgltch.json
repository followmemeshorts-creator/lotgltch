function hexToLottieColor(hex) {
  hex = hex.replace('#', '');
  if (hex.length === 3) hex = hex.split('').map(c => c + c).join('');
  const r = parseInt(hex.slice(0, 2), 16) / 255;
  const g = parseInt(hex.slice(2, 4), 16) / 255;
  const b = parseInt(hex.slice(4, 6), 16) / 255;
  return [r, g, b, 1];
}

// Парсинг одного тега — возвращает объект атрибутов
function parseAttrs(attrString) {
  const attrs = {};
  // Матчим key="value" или key='value'
  const re = /([\w:\-]+)\s*=\s*(?:"([^"]*)"|'([^']*)')/g;
  let m;
  while ((m = re.exec(attrString)) !== null) {
    attrs[m[1]] = m[2] !== undefined ? m[2] : m[3];
  }
  return attrs;
}

// Получить значение свойства: сначала из style="...", потом из атрибута
function getProp(attrs, prop) {
  const style = attrs['style'] || '';
  const styleMatch = style.match(new RegExp('(?:^|;)\\s*' + prop + '\\s*:\\s*([^;]+)'));
