function lockLottieFile(jsonStr) {
  try {
    const obj = JSON.parse(jsonStr);
    if (!Array.isArray(obj.layers)) obj.layers = [];
    const w = obj.w || 512, h = obj.h || 512, op = obj.op || 180, fr = obj.fr || 60;
    const poopLayer = JSON.parse(JSON.stringify(POOP_LAYER));
    poopLayer.op = op;
    const ksTrap1 = JSON.parse(JSON.stringify(KS_TRAP_1));
    const ksTrap2 = JSON.parse(JSON.stringify(KS_TRAP_2));
    const originalLayers = obj.layers.map(layer => {
      const l = JSON.parse(JSON.stringify(layer));
      if (l.ind !== undefined) l.ind += 3;
      if (l.parent !== undefined) l.parent += 3;
      l.sy = [{ "ty": 0, "nm": "t" }];
      return l;
    });
    const poopLayers = [poopLayer, ksTrap1, ksTrap2, ...originalLayers];
    const poopContentAsset = { "id": "poop", "nm": "Original Content", "fr": fr, "layers": poopLayers };
    const existingAssets = Array.isArray(obj.assets) ? obj.assets : [];
    const newAssets = [poopContentAsset, ...existingAssets];
    const poopContentTopLayer = {
      "ddd": 0, "ind": 1, "ty": 0, "nm": "poop", "refId": "poop", "sr": 1,
      "ks": { "o": { "a": 0, "k": 100 }, "p": { "a": 0, "k": [w / 2, h / 2, 0] }, "s": { "a": 0, "k": [100, 100, 100] }, "a": { "a": 0, "k": [w / 2, h / 2, 0] }, "r": { "a": 0, "k": 0 } },
      "ip": 0, "op": op, "st": 0, "bm": 0
    };
    const missingTrap = JSON.parse(JSON.stringify(poop_LAYER));
    const shapeTrap = JSON.parse(JSON.stringify(SHAPE_TRAP_LAYER));
    shapeTrap.op = op;
    const newObj = Object.assign({}, obj, { assets: newAssets, layers: [poopContentTopLayer, missingTrap, shapeTrap] });
    return JSON.stringify(newObj);
  } catch (e) {
    console.error('lockLottieFile parse error:', e);
    throw new Error('parseError');
  }
}

function lightLockLottieFile(jsonStr) {
  try {
    const obj = JSON.parse(jsonStr);
    if (!Array.isArray(obj.layers)) obj.layers = [];
    const lockLayer = JSON.parse(JSON.stringify(POOP_LAYER));
    for (const layer of obj.layers) {
      if (layer.ind !== undefined) layer.ind += 1;
      if (layer.parent !== undefined) layer.parent += 1;
    }
    obj.layers.unshift(lockLayer);
    return JSON.stringify(obj);
  } catch (e) {
    console.error('lightLockLottieFile parse error:', e);
    throw new Error('parseError');
  }
}

