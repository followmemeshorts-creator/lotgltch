      }
      case 'c': {
        const cx1 = curX + n(), cy1 = curY + n(), cx2 = curX + n(), cy2 = curY + n(), ex = curX + n(), ey = curY + n();
        if (outTangents.length > 0) outTangents[outTangents.length - 1] = [cx1 - curX, cy1 - curY];
        verts.push([ex, ey]); inTangents.push([cx2 - ex, cy2 - ey]); outTangents.push([0, 0]);
        curX = ex; curY = ey; break;
      }
      case 'S': {
        const prevO = outTangents[outTangents.length - 1] || [0, 0];
        const cx1 = curX - prevO[0], cy1 = curY - prevO[1];
        const cx2 = n(), cy2 = n(), ex = n(), ey = n();
        if (outTangents.length > 0) outTangents[outTangents.length - 1] = [cx1 - curX, cy1 - curY];
        verts.push([ex, ey]); inTangents.push([cx2 - ex, cy2 - ey]); outTangents.push([0, 0]);
        curX = ex; curY = ey; break;
      }
      case 's': {
        const prevO = outTangents[outTangents.length - 1] || [0, 0];
        const cx1 = curX - prevO[0], cy1 = curY - prevO[1];
        const cx2 = curX + n(), cy2 = curY + n(), ex = curX + n(), ey = curY + n();
        if (outTangents.length > 0) outTangents[outTangents.length - 1] = [cx1 - curX, cy1 - curY];
        verts.push([ex, ey]); inTangents.push([cx2 - ex, cy2 - ey]); outTangents.push([0, 0]);
        curX = ex; curY = ey; break;
      }
      case 'Q': {
        const qx1 = n(), qy1 = n(), qex = n(), qey = n();
        if (outTangents.length > 0) outTangents[outTangents.length - 1] = [(qx1 - curX) * 2 / 3, (qy1 - curY) * 2 / 3];
        verts.push([qex, qey]); inTangents.push([(qx1 - qex) * 2 / 3, (qy1 - qey) * 2 / 3]); outTangents.push([0, 0]);
        curX = qex; curY = qey; break;
      }
      case 'q': {
        const qx1 = curX + n(), qy1 = curY + n(), qex = curX + n(), qey = curY + n();
        if (outTangents.length > 0) outTangents[outTangents.length - 1] = [(qx1 - curX) * 2 / 3, (qy1 - curY) * 2 / 3];
        verts.push([qex, qey]); inTangents.push([(qx1 - qex) * 2 / 3, (qy1 - qey) * 2 / 3]); outTangents.push([0, 0]);
        curX = qex; curY = qey; break;
      }
      case 'Z': case 'z': { closed = true; curX = startX; curY = startY; break; }
      default: { if (!isNaN(parseFloat(tok))) { /* уже потреблено через lastCmd */ } break; }
    }
  }
  pushShape();
  return shapes;
}

// Строим один Lottie shape-layer из атрибутов SVG-элемента
function buildLottieLayer(tag, attrs, scaleX, scaleY, ind, op) {
  const fill = getProp(attrs, 'fill');
  const stroke = getProp(attrs, 'stroke');
  const strokeWidth = getProp(attrs, 'stroke-width');
  const opacity = getProp(attrs, 'opacity') || getProp(attrs, 'fill-opacity');

  const groupItems = [];

  if (tag === 'path') {
    const d = attrs['d'];
    if (!d) return null;
    const segs = parseSvgPathToLottie(d);
    if (segs.length === 0) return null;
    segs.forEach((seg, idx) => {
      groupItems.push({
        ty: 'sh', ix: idx + 1,
        ks: {
          a: 0,
          k: {
            i: seg.i.map(p => [p[0] * scaleX, p[1] * scaleY]),
            o: seg.o.map(p => [p[0] * scaleX, p[1] * scaleY]),
            v: seg.v.map(p => [p[0] * scaleX, p[1] * scaleY]),
            c: seg.c
          },
          ix: 2
        },
        nm: 'Path ' + (idx + 1), mn: 'ADBE Vector Shape - Group', hd: false
      });
    });
  } else if (tag === 'rect') {
    const rx = parseFloat(attrs['x'] || 0) * scaleX;
    const ry = parseFloat(attrs['y'] || 0) * scaleY;
    const rw = parseFloat(attrs['width'] || 0) * scaleX;
    const rh = parseFloat(attrs['height'] || 0) * scaleY;
    groupItems.push({
      ty: 'rc', ix: 1, d: 1,
      s: { a: 0, k: [rw, rh], ix: 2 },
      p: { a: 0, k: [rx + rw / 2, ry + rh / 2], ix: 3 },
      r: { a: 0, k: parseFloat(attrs['rx'] || 0) * scaleX, ix: 4 },
      nm: 'Rect', mn: 'ADBE Vector Shape - Rect', hd: false
    });
  } else if (tag === 'circle' || tag === 'ellipse') {
    const cx = parseFloat(attrs['cx'] || 0) * scaleX;
    const cy = parseFloat(attrs['cy'] || 0) * scaleY;
    const rx = parseFloat(attrs['r'] || attrs['rx'] || 0) * scaleX;
    const ry = parseFloat(attrs['ry'] || attrs['r'] || 0) * scaleY;
    groupItems.push({
      ty: 'el', ix: 1, d: 1,
      s: { a: 0, k: [rx * 2, ry * 2], ix: 2 },
      p: { a: 0, k: [cx, cy], ix: 3 },
      nm: 'Ellipse', mn: 'ADBE Vector Shape - Ellipse', hd: false
    });
  } else if (tag === 'line') {
    const x1 = parseFloat(attrs['x1'] || 0) * scaleX;
    const y1 = parseFloat(attrs['y1'] || 0) * scaleY;
    const x2 = parseFloat(attrs['x2'] || 0) * scaleX;
    const y2 = parseFloat(attrs['y2'] || 0) * scaleY;
    groupItems.push({
      ty: 'sh', ix: 1,
      ks: { a: 0, k: { i: [[0,0],[0,0]], o: [[0,0],[0,0]], v: [[x1,y1],[x2,y2]], c: false }, ix: 2 },
      nm: 'Line', mn: 'ADBE Vector Shape - Group', hd: false
    });
  } else if (tag === 'polyline' || tag === 'polygon') {
    const pts = (attrs['points'] || '').trim().split(/[\s,]+/);
    const v = [];
    for (let j = 0; j + 1 < pts.length; j += 2) {
      v.push([parseFloat(pts[j]) * scaleX, parseFloat(pts[j + 1]) * scaleY]);
    }
    if (v.length < 2) return null;
    const iArr = v.map(() => [0, 0]);
    const oArr = v.map(() => [0, 0]);
    groupItems.push({
      ty: 'sh', ix: 1,
      ks: { a: 0, k: { i: iArr, o: oArr, v, c: tag === 'polygon' }, ix: 2 },
      nm: 'Poly', mn: 'ADBE Vector Shape - Group', hd: false
    });
  } else {
    return null;
  }

  if (groupItems.length === 0) return null;

  // Заливка — если url() или none → используем чёрную как fallback (при перекраске всё равно заменится)
  const fillColor = parseColor(fill);
  if (fill !== 'none') {
    groupItems.push({
      ty: 'fl',
      c: { a: 0, k: fillColor || [0, 0, 0, 1], ix: 4 },
      o: { a: 0, k: 100, ix: 5 }, r: 1, bm: 0,
      nm: 'Fill', mn: 'ADBE Vector Graphic - Fill', hd: false
    });
  }

  // Обводка
  const strokeColor = parseColor(stroke);
  if (stroke && stroke !== 'none') {
    const sw = parseFloat(strokeWidth || '1') * Math.max(scaleX, scaleY);
    groupItems.push({
      ty: 'st',
      c: { a: 0, k: strokeColor || [0, 0, 0, 1], ix: 3 },
      o: { a: 0, k: 100, ix: 4 },
      w: { a: 0, k: sw, ix: 5 },
      lc: 2, lj: 2, bm: 0,
      nm: 'Stroke', mn: 'ADBE Vector Graphic - Stroke', hd: false
    });
  }

  // Если нет ни fill ни stroke — добавляем дефолтный чёрный fill
  const hasFill = groupItems.some(it => it.ty === 'fl');
  const hasStroke = groupItems.some(it => it.ty === 'st');
  if (!hasFill && !hasStroke) {
    groupItems.push({
      ty: 'fl', c: { a: 0, k: [0, 0, 0, 1], ix: 4 },
      o: { a: 0, k: 100, ix: 5 }, r: 1, bm: 0,
      nm: 'Fill', mn: 'ADBE Vector Graphic - Fill', hd: false
    });
  }

  groupItems.push({
    ty: 'tr',
    p: { a: 0, k: [0, 0], ix: 2 }, a: { a: 0, k: [0, 0], ix: 1 },
    s: { a: 0, k: [100, 100], ix: 3 }, r: { a: 0, k: 0, ix: 6 },
    o: { a: 0, k: opacity ? Math.round(parseFloat(opacity) * 100) : 100, ix: 7 },
    sk: { a: 0, k: 0, ix: 4 }, sa: { a: 0, k: 0, ix: 5 }, nm: 'Transform'
  });

  return {
    ddd: 0, ind, ty: 4, nm: tag, sr: 1,
    ks: {
      o: { a: 0, k: 100, ix: 11 }, r: { a: 0, k: 0, ix: 10 },
      p: { a: 0, k: [0, 0, 0], ix: 2, l: 2 }, a: { a: 0, k: [0, 0, 0], ix: 1, l: 2 },
      s: { a: 0, k: [100, 100, 100], ix: 6, l: 2 }
    },
    ao: 0,
    shapes: [{
      ty: 'gr', it: groupItems,
      nm: 'Group', np: groupItems.length, cix: 2, bm: 0, ix: 1,
      mn: 'ADBE Vector Group', hd: false
    }],
    ip: 0, op, st: 0, ct: 1, bm: 0
  };
}

// Regex-парсинг SVG строки → плоский список тегов с атрибутами (без DOMParser)
function parseSvgString(svgString) {
  // Убираем комментарии и XML declaration
  svgString = svgString.replace(/<!--[\s\S]*?-->/g, '').replace(/<\?xml[^>]*\?>/g, '');

  // viewBox / размеры из <svg ...>
  const svgTagMatch = svgString.match(/<svg([^>]*)>/i);
  if (!svgTagMatch) throw new Error('invalidSvg');
  const svgAttrs = parseAttrs(svgTagMatch[1]);

  let origW = 512, origH = 512;
  const vb = svgAttrs['viewBox'];
  if (vb) {
    const parts = vb.trim().split(/[\s,]+/);
    if (parts.length >= 4) { origW = parseFloat(parts[2]); origH = parseFloat(parts[3]); }
  } else {
    origW = parseFloat(svgAttrs['width'] || 512);
    origH = parseFloat(svgAttrs['height'] || 512);
  }

  const scaleX = 512 / origW;
  const scaleY = 512 / origH;

  // Ищем все shape-теги (самозакрывающиеся и парные)
  const shapeRe = /<(path|rect|circle|ellipse|line|polyline|polygon)\s([^>]*?)\/?>/gi;
  const layers = [];
  let ind = 1;
  let m;

  // Также учитываем <g> transform для дочерних элементов — упрощённо: берём transform только самого элемента
  while ((m = shapeRe.exec(svgString)) !== null) {
    const tag = m[1].toLowerCase();
    const attrs = parseAttrs(m[2]);

    // Наследуем fill/stroke из ближайшей <g> если не заданы явно
    // (упрощённо: ищем последний открытый <g> перед этим тегом)
    const before = svgString.slice(0, m.index);
    const gMatches = [...before.matchAll(/<g([^>]*)>/gi)];
    if (gMatches.length > 0) {
      const gAttrs = parseAttrs(gMatches[gMatches.length - 1][1]);
      if (!attrs['fill'] && gAttrs['fill']) attrs['fill'] = gAttrs['fill'];
      if (!attrs['stroke'] && gAttrs['stroke']) attrs['stroke'] = gAttrs['stroke'];
      if (!attrs['stroke-width'] && gAttrs['stroke-width']) attrs['stroke-width'] = gAttrs['stroke-width'];
      if (!attrs['style'] && gAttrs['style']) attrs['style'] = gAttrs['style'];
      // transform из <g>
      if (!attrs['transform'] && gAttrs['transform']) attrs['_gtransform'] = gAttrs['transform'];
    }

    const op = 180;
    const layer = buildLottieLayer(tag, attrs, scaleX, scaleY, ind, op);
    if (layer) { layers.push(layer); ind++; }
  }

  if (layers.length === 0) throw new Error('invalidSvg');

  return layers;
}

// Перекраска всех fill/stroke в layers в нужный hex
function recolorLottieLayers(layers, hexColor) {
  const color = hexToLottieColor(hexColor);

  function recolorItem(item) {
    if (!item || typeof item !== 'object') return;
    if (item.ty === 'fl' || item.ty === 'gf') {
      item.ty = 'fl';
      item.c = { a: 0, k: color, ix: 4 };
      delete item.g; delete item.s; delete item.e; delete item.t;
      item.o = item.o || { a: 0, k: 100, ix: 5 };
      item.r = 1; item.bm = 0;
      item.nm = item.nm || 'Fill';
      item.mn = 'ADBE Vector Graphic - Fill';
    }
    if (item.ty === 'st' || item.ty === 'gs') {
      item.ty = 'st';
      item.c = { a: 0, k: color, ix: 3 };
      delete item.g; delete item.s; delete item.e; delete item.t;
      item.o = item.o || { a: 0, k: 100, ix: 4 };
      item.nm = item.nm || 'Stroke';
      item.mn = 'ADBE Vector Graphic - Stroke';
    }
    if (Array.isArray(item.it)) item.it.forEach(recolorItem);
    if (Array.isArray(item.shapes)) item.shapes.forEach(recolorItem);
  }

  for (const layer of layers) {
    if (Array.isArray(layer.shapes)) layer.shapes.forEach(recolorItem);
  }
}

// Главная функция: SVG string → { origLayers, greenLayers, blueLayers }
function svgToGlitchLayers(svgString) {
  const origLayers = parseSvgString(svgString);
  const greenLayers = JSON.parse(JSON.stringify(origLayers));
  recolorLottieLayers(greenLayers, '62FF38');
  const blueLayers = JSON.parse(JSON.stringify(origLayers));
  recolorLottieLayers(blueLayers, 'F837FF');
  return { origLayers, greenLayers, blueLayers };
}
// ─────────────────────────────────────────────────────────────────────────────
// Сборка финального Lottie из шаблона + наши слои
function buildGlitchLottie(origLayers, greenLayers, blueLayers) {
  let template;
  try {
    template = JSON.parse(GLITCH_TEMPLATE_JSON);
  } catch (e) {
    throw new Error('Glitch template parse error: ' + e.message);
  }

  if (!Array.isArray(template.assets)) template.assets = [];

  function upsertAsset(id, nm, layers) {
    let asset = template.assets.find(a => a.id === id);
    if (!asset) {
      asset = { id, nm, fr: 60, layers: [] };
      template.assets.push(asset);
    }
    asset.layers = layers;
    asset.nm = nm;
  }

  upsertAsset('comp_1', 'orig group', origLayers);
  upsertAsset('comp_2', 'green group', greenLayers);
  upsertAsset('comp_3', 'blue group', blueLayers);

  return JSON.stringify(template);
}
async function processSvgFile(fileId, fileName, chatId, userId) {
  try {
    const fileResponse = await fetch(`${TELEGRAM_API}/getFile?file_id=${fileId}`);
    const fileData = await fileResponse.json();
    if (!fileData.ok) throw new Error('getFileError');

    const filePath = fileData.result.file_path;
    const downloadUrl = `https://api.telegram.org/file/bot${TELEGRAM_BOT_TOKEN}/${filePath}`;
    const svgBuffer = await fetch(downloadUrl).then(r => r.arrayBuffer());
    const svgString = new TextDecoder().decode(new Uint8Array(svgBuffer));

    let origLayers, greenLayers, blueLayers;
    try {
      ({ origLayers, greenLayers, blueLayers } = svgToGlitchLayers(svgString));
    } catch (e) {
      throw new Error('invalidSvg');
    }

    const lottieJson = buildGlitchLottie(origLayers, greenLayers, blueLayers);

    // Валидация
    try { JSON.parse(lottieJson); } catch (e) { throw new Error('corruptedFile'); }

    const tgsBuffer = await compressToTGS(lottieJson);

    const baseName = fileName.replace(/\.svg$/i, '');
    const sanitize = n => n.replace(/[<>:"|?*]/g, '_').substring(0, 255);
    const tgsFileName = sanitize(`${baseName}_glitch.tgs`);

    const tgsBlob = new Blob([tgsBuffer], { type: 'application/octet-stream' });
    const tgsFormData = new FormData();
    tgsFormData.append('chat_id', chatId);
    tgsFormData.append('document', tgsBlob, tgsFileName);
    await fetch(`${TELEGRAM_API}/sendDocument`, { method: 'POST', body: tgsFormData });

    if (tgsBuffer.length > TGS_SIZE_WARNING_THRESHOLD) {
      await fetch(`${TELEGRAM_API}/sendMessage`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ chat_id: chatId, text: t(userId, 'tgsSizeWarning') })
      });
    }

    await fetch(`${TELEGRAM_API}/sendMessage`, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ chat_id: chatId, text: t(userId, 'glitchDone') })
    });

    console.log(`✅ SVG glitch done: ${fileName}`);
  } catch (error) {
    console.error('processSvgFile error:', error);
    throw error;
  }
}

